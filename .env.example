# API (apps/api)
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resume
JWT_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
WEB_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# Email (verification emails). If both unset, signup works but no verification email is sent.
# Easiest: Resend — 3,000 emails/month free. Get API key at https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM=ResumeFlow <onboarding@resend.dev>
# Or use SMTP:
# SMTP_URL=smtps://user:pass@smtp.example.com:465
# EMAIL_FROM=ResumeFlow <noreply@yourdomain.com>

# Optional: for future AI features
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
